<style>


    .top-bar {
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255,255,255,0.2);
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        border-radius: 18px;
        margin-top: 20px;
        padding: 6px 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .top-left {
        display: flex;
        gap: 25px;
        align-items: center;
    }

    .top-right {
        display: flex;
        align-items: center;
    }

    .top-link {
        color: white;
        text-decoration: none;
        font-size: 15px;
        font-weight: 500;
        transition: 0.3s;
    }

        .top-link:hover {
            color: #dcdcdc;
        }

    .active-link {
        border-bottom: 2px solid white;
        padding-bottom: 4px;
    }

    .logout-btn {
        text-decoration: none;
        color: white;
        padding: 5px 18px;
        border-radius: 10px;
        transition: 0.3s;
        font-weight: 400;
    }

        .logout-btn:hover {
            /*        background: rgba(220,53,69,1);*/
            color: rgba(220,53,69,1);
        }
</style>

<div class="row">

    <div class="col-sm-12">

        <div class="top-bar">

            <!-- Left Side -->
            <div class="top-left">

                <a href="/Expense/Index" class="top-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active-link" : "")">
                    Index
                </a>

                <a href="/Report/ReportDashboard" class="top-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ReportDashboard" ? "active-link" : "")">
                    Report Dashboard
                </a>

            </div>

            <!-- Right Side -->
            <div class="top-right">

                <a href="/Auth/Logout" class="logout-btn">
                    Logout
                </a>

            </div>

        </div>

    </div>

</div>